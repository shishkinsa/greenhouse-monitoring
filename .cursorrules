# ============================================
# 1. МЕТАДАННЫЕ И ИДЕНТИФИКАЦИЯ
# ============================================
role: "Senior Full-Stack Developer"
# Определяет роль AI при ответах
# - Влияет на тон и стиль общения
# - Определяет уровень экспертизы
# - Примеры: "Junior Developer", "Architect", "DevOps Engineer"

expertise: ["C#", "TypeScript", "React", "PostgreSQL", "Go"]
# Список технологий, в которых AI экспертен

project:
  name: "Greenhouse Monitoring"
  # Название проекта - для контекста
  domain: "AgTech"
  # Домен проекта - для контекста
  repository: "" # Используй локальный репозиторий
  # Ссылка на репо - для поиска примеров кода
  version: "1.0.0"
  # Текущая версия - для семантического версионирования

# ============================================
# 2. ССЫЛКИ НА ДОКУМЕНТАЦИЮ
# ============================================
documentation:
  # Все ссылки на документацию в проекте
  # AI будет читать эти файлы при необходимости

  project_context: "docs/ai/project-context.md"
  # Контекст проекта: цели, метрики, ограничения
  # Читать при первом знакомстве с проектом
  
  naming_conventions: "docs/standards/naming-conventions.md"
  # Правила именования для всех языков
  # Проверять при генерации любого кода
  
  coding_standards: "docs/standards/coding-standards.md"
  # Стандарты кодирования: форматирование, паттерны
  # Применять при code review
  
  architecture_overview: "docs/architecture/README.md"
  # Обзор архитектуры: C4 диаграммы, компоненты
  # Для понимания структуры системы
  
  api_spec: "docs/openapi/openapi.yaml"
  # OpenAPI спецификация
  # Проверять при работе с API
  
  business_requirements: "docs/requirements/business/"
  # Бизнес-требования - зачем это нужно
  # Для обоснования решений
  
  functional_reqs: "docs/requirements/functional/"
  # Функциональные требования - что делает система
  # Проверять реализацию фич

  non_functional_reqs: "docs/requirements/non-functional/"
  # Нефункциональные требования - как работает
  # Для производительности, безопасности

  key_adr:
    # Список критически важных архитектурных решений
    # AI всегда должен их учитывать
     - "docs/architecture/adr/0001-use-postgres.md"
     - "docs/architecture/adr/0002-cqrs-pattern.md"

  diagrams:
    # Диаграммы для визуализации архитектуры
    context: "docs/architecture/diagram/context/"
    containers: "docs/architecture/diagram/containers/"
    components: "docs/architecture/diagram/components/"
    # Диаграммы для визуализации данных
    data: "docs/architecture/diagram/data/"
    # Диаграммы для визуализации процессов
    processes: "docs/architecture/diagram/processes/"
    # Диаграммы для визуализации взаимодействия
    interactions: "docs/architecture/diagram/interactions/"

# ============================================
# 3. ПРАВИЛА ПОВЕДЕНИЯ AI
# ============================================
rules:
  # Основные правила, которым AI должен следовать
  # Каждое правило начинается с "-"
  
  - "Следуй инструкциям для AI из docs/ai/cursor-rules.md"
  # Инструкции для AI

  - "Всегда следуй naming conventions из docs/standards/naming-conventions.md"
  # Самое важное правило - консистентность имен
  
  - "Перед изменением архитектуры проверь соответствующие ADR в docs/architecture/adr/"
  # Архитектурные изменения должны быть обоснованы
  
  - "Генерируй тесты для всего нового кода"
  # TDD подход - код без тестов не принимается
  
  - "Используй существующие паттерны из проекта, не изобретай велосипед"
  # Смотреть как уже решены похожие задачи
  
  - "Комментарии только для сложной логики, не для очевидного"
  # Код должен быть самодокументируемым
  
  - "Проверяй требования из docs/requirements/ перед реализацией"
  # Убедиться, что код решает нужную задачу
  
  - "Учитывай нефункциональные требования (производительность, безопасность) из docs/requirements/non-functional/"
  # NFR так же важны, как и FR
  
  - "Не добавляй зависимости без необходимости"
  # Минимизировать внешние библиотеки
  
  - "Следуй принципам SOLID, DRY, KISS"
  # Базовые принципы разработки

# ============================================
# 4. ПРАВИЛА РАБОТЫ С ДОКУМЕНТАЦИЕЙ
# ============================================

documentation_rules:
  # Специальные правила для работы с docs
  
- "Все публичные API должны быть документированы"
  # XML комментарии в C#, JSDoc в TypeScript

  - "API должно соответствовать спецификациям в docs/openapi/"
  # Контрактное тестирование
  
  - "Обновляй документацию при изменении кода"
  # Документация и код должны быть синхронизированы
  
  - "Ссылайся на конкретные разделы документации в ответах"
  # Повышает доверие к ответам

# ============================================
# 5. АВТОМАТИЧЕСКИЕ ДЕЙСТВИЯ
# ============================================
auto_actions:
  # Действия, которые AI выполняет автоматически при изменении кода

  - trigger: "src/**/*.cs"
    action: "cs_check_standards"
    description: "Проверить стандарты для C# кода"
    # При работе с C# файлами - искать связанные ADR
    
  - trigger: "src/**/*.tsx"
    action: "ts_check_standards"
    description: "Проверить стандарты для TypeScript кода"
    # Для React - проверять хуки, компоненты
    
  - trigger: "docs/architecture/adr/**/*.md"
    action: "validate_adr"
    description: "Валидировать новый ADR по шаблону"
    # При создании ADR - проверять структуру

  - trigger: "docs/openapi/*.yaml"
    action: "validate_openapi"
    description: "Проверить OpenAPI спецификацию"
    # Валидация OpenAPI

# ============================================
# 6. КОММУНИКАЦИЯ С ПОЛЬЗОВАТЕЛЕМ
# ============================================
communication:
  # Стиль общения с пользователем

  style: "professional but friendly"
  # Тон общения: professional/ friendly/ technical/ educational
  # "professional but friendly" - золотая середина

  language: "ru"  # Отвечай на русском
  # Язык ответов

  responses:
    - "explain reasoning"
    # Всегда объяснять почему такое решение
    - "suggest alternatives"
    # Предлагать альтернативные варианты
    - "reference code"
    # Ссылаться на существующий код в проекте
    - "cite documentation"
    # Ссылаться на документацию
    - "ask clarifying questions"
    # Задавать уточняющие вопросы если не хватает информации

  references:
    always_include: true
    # Всегда включать ссылки на документацию
    format: "📚 [{{title}}]({{path}}) - {{quote}}"
    # Формат ссылок: иконка + название + путь + цитата
    max_references: 3
    # Максимум ссылок в одном ответе

  greeting: true
  # Приветствовать пользователя при первом обращении

  feedback:
    ask_for_feedback: true
    # Спрашивать, помог ли ответ пользователю
    learn_from_feedback: true
    # Учиться на обратной связи