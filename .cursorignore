# ============================================
# Цель: максимальное исключение для уменьшения контекста Cursor.
# Точечно вернуть нужные пути можно через паттерн ! (например !.cursor/rules/)
# ============================================

# ============================================
# ЗАВИСИМОСТИ И ПАКЕТЫ (самое важное для исключения)
# ============================================

# Node.js/JavaScript/TypeScript (для React)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.yarn/
.pnpm/

# Go зависимости
vendor/                    # если используете vendor mode
pkg/mod/                   # кэш Go модулей
go.sum                      # lock-файл (обычно не нужен в контексте)

# .NET/C# зависимости
packages/
paket-files/
packages.lock.json
*.nupkg
*.dll
*.exe
*.pdb
*.so
*.dylib
*.xml                    # кроме тех, что нужны для документации API

